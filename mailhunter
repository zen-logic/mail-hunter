#!/usr/bin/env python3
"""Mail Hunter launcher — equivalent to: python -m mail_hunter"""

if __name__ == "__main__":
    import sys

    REQUIRED_PACKAGES = {
        "starlette": "starlette",
        "uvicorn": "uvicorn[standard]",
        "aiosqlite": "aiosqlite",
        "multipart": "python-multipart",
    }

    missing = []
    for module, pkg in REQUIRED_PACKAGES.items():
        try:
            __import__(module)
        except ImportError:
            missing.append(pkg)

    if missing:
        print("Error: Missing required packages:")
        for pkg in missing:
            print(f"  - {pkg}")
        print()
        print("Install them with:")
        print(f"  pip install {' '.join(missing)}")
        sys.exit(1)

    import runpy
    runpy.run_module("mail_hunter", run_name="__main__")
